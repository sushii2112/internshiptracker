# Copy to .env and fill in. These are exposed to the browser (VITE_ prefix),
# which is expected — the Supabase anon key is public and protected by RLS.
# Set the same variables in your host's dashboard (e.g. Vercel → Settings → Environment Variables).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: enables Gmail import. An OAuth "Web application" client ID from Google Cloud.
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
